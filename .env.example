# House-v3 Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── LLM Providers ────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here          # Optional — only if using Anthropic directly

# ── Hugging Face (for gated model downloads) ─
HF_TOKEN=hf_your-token-here                     # Optional — only for TOS-gated models

# ── Discord Bot Tokens ───────────────────────
# Each persona runs as its own Discord bot.
# Create 6 bots at https://discord.com/developers/applications
# Each bot needs: Bot → Privileged Gateway Intents → MESSAGE CONTENT enabled
DISCORD_TOKEN_WATCHER=your-watcher-bot-token
DISCORD_TOKEN_ELVIRA=your-elvira-bot-token
DISCORD_TOKEN_FRANK=your-frank-bot-token
DISCORD_TOKEN_ZAGNA=your-zagna-bot-token
DISCORD_TOKEN_VIRELINE=your-vireline-bot-token
DISCORD_TOKEN_ELLIE=your-ellie-bot-token
